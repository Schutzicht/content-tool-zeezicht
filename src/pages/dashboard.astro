---
import Layout from '../layouts/Layout.astro';
import supabase from '../db/db';

// --- LOGIC: Handle POST requests for updating/deleting/moving ---
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const action = data.get('action'); 
    const id = data.get('id');

    if (id && action === 'delete') {
      const { error } = await supabase.from('content_ideas').delete().eq('id', id.toString());
      if (error) console.error(error);
    } else if (id && action === 'update_status') {
      const status = data.get('status');
      const { error } = await supabase.from('content_ideas').update({ status: status?.toString() || 'pending' }).eq('id', id.toString());
      if (error) console.error(error);
    } else if (id && action === 'move') {
      const plannedDate = data.get('planned_date'); // e.g. "2026-03-12" or "null" (backlog)
      const { error } = await supabase.from('content_ideas').update({ planned_date: plannedDate === 'null' ? null : plannedDate?.toString() }).eq('id', id.toString());
      if (error) console.error(error);
    }
  } catch (err) {
    console.error('Action failed:', err);
  }
}

// --- LOGIC: Fetch Data ---
const { data: rows, error } = await supabase.from('content_ideas').select('*').order('created_at', { ascending: false });
if (error) console.error("Error fetching ideas:", error);

const allIdeas = (rows || []) as {
  id: number;
  submitter: string;
  idea: string;
  hook: string | null;
  visuals: string | null;
  target_url: string | null;
  status: string;
  planned_date: string | null;
  created_at: string;
}[];

// --- LOGIC: Calendar Calculation ---
const url = new URL(Astro.request.url);
const now = new Date();

// Use URL params or fallback to current month/year
let currentYear = parseInt(url.searchParams.get('year') || now.getFullYear().toString());
let currentMonth = parseInt(url.searchParams.get('month') || (now.getMonth() + 1).toString());

// Handle prev/next wrap-around
if (currentMonth < 1) {
  currentMonth = 12;
  currentYear -= 1;
} else if (currentMonth > 12) {
  currentMonth = 1;
  currentYear += 1;
}

const prevMonthUrl = `?year=${currentMonth === 1 ? currentYear - 1 : currentYear}&month=${currentMonth === 1 ? 12 : currentMonth - 1}`;
const nextMonthUrl = `?year=${currentMonth === 12 ? currentYear + 1 : currentYear}&month=${currentMonth === 12 ? 1 : currentMonth + 1}`;

const monthNames = ['Januari', 'Februari', 'Maart', 'April', 'Mei', 'Juni', 'Juli', 'Augustus', 'September', 'Oktober', 'November', 'December'];
const currentMonthName = monthNames[currentMonth - 1];

// Calendar Grid Builder
const firstDayOfMonth = new Date(currentYear, currentMonth - 1, 1);
const lastDayOfMonth = new Date(currentYear, currentMonth, 0);
const daysInMonth = lastDayOfMonth.getDate();

// JavaScript getDay() returns 0 for Sunday, 1 for Monday. We want Monday to be 0 for our grid.
let startDayOfWeek = firstDayOfMonth.getDay() - 1;
if (startDayOfWeek === -1) startDayOfWeek = 6; // Sunday becomes 6

const calendarCells: { dateStr: string; dayNumber: number; inCurrentMonth: boolean }[] = [];

// Prefix with empty cells for previous month padding
for (let i = 0; i < startDayOfWeek; i++) {
  calendarCells.push({ dateStr: '', dayNumber: 0, inCurrentMonth: false });
}

// Actual days of the month
for (let i = 1; i <= daysInMonth; i++) {
  const padMonth = currentMonth.toString().padStart(2, '0');
  const padDay = i.toString().padStart(2, '0');
  calendarCells.push({ 
    dateStr: `${currentYear}-${padMonth}-${padDay}`, 
    dayNumber: i, 
    inCurrentMonth: true 
  });
}

// Suffix with empty cells to fill the row (multiple of 7)
while (calendarCells.length % 7 !== 0) {
  calendarCells.push({ dateStr: '', dayNumber: 0, inCurrentMonth: false });
}

// Group Ideas
const backlogIdeas = allIdeas.filter(i => !i.planned_date);
const plannedIdeasByDate = allIdeas.filter(i => i.planned_date).reduce((acc, idea) => {
  if (!acc[idea.planned_date!]) acc[idea.planned_date!] = [];
  acc[idea.planned_date!].push(idea);
  return acc;
}, {} as Record<string, typeof allIdeas>);

const avatars: Record<string, string> = {
  'Jorik': 'https://zeezichtwebsitecms-production.up.railway.app/assets/46afab71-4fc1-4d4d-a747-7c34bed81207',
  'Jorian': 'https://zeezichtwebsitecms-production.up.railway.app/assets/582b20ad-b110-43f1-8d5e-1fcbf80869bb',
  'Ruben': 'https://zeezichtwebsitecms-production.up.railway.app/assets/683c0474-6aab-44aa-a5bc-2e64c3090010'
};
---

<Layout title="Contentkalender - Pheadra">
  <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-brand-navy mb-2">Contentkalender</h1>
      <p class="text-brand-slate">Visueel inplannen geselecteerde posts door oppakken en direct in een dag te slepen.</p>
    </div>
  </div>

  <!-- Hidden Form to trigger Move Actions -->
  <form id="move-form" method="POST" class="hidden">
    <input type="hidden" name="action" value="move" />
    <input type="hidden" name="id" id="move-id" />
    <input type="hidden" name="planned_date" id="move-date" />
  </form>

  <div class="flex flex-col xl:flex-row gap-8 items-start">
    
    <!-- LEFT: Calendar Area -->
    <div class="flex-grow w-full xl:w-3/4">
      <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden flex flex-col h-full">
        <!-- Calendar Header Controls -->
        <div class="p-4 border-b border-gray-200 flex items-center justify-between bg-gray-50">
          <a href={prevMonthUrl} class="px-3 py-1.5 text-sm font-medium text-brand-teal hover:bg-brand-sky rounded-md transition-colors flex items-center gap-1">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            Vorige
          </a>
          <h2 class="text-xl font-bold text-brand-navy tracking-tight">{currentMonthName} {currentYear}</h2>
          <a href={nextMonthUrl} class="px-3 py-1.5 text-sm font-medium text-brand-teal hover:bg-brand-sky rounded-md transition-colors flex items-center gap-1">
            Volgende
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>
        
        <!-- Day Names -->
        <div class="grid grid-cols-7 border-b border-gray-200 bg-gray-100">
          {['Ma', 'Di', 'Wo', 'Do', 'Vr', 'Za', 'Zo'].map(day => (
            <div class="py-2 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider border-r last:border-r-0 border-gray-200">
              {day}
            </div>
          ))}
        </div>

        <!-- Calendar Grids -->
        <div class="grid grid-cols-7 auto-rows-[minmax(120px,_1fr)] flex-grow">
          {calendarCells.map((cell, idx) => (
            <div 
              class={`border-b border-r border-gray-100 last:border-r-0 relative group p-1 flex flex-col ${cell.inCurrentMonth ? 'bg-white' : 'bg-gray-50'}`}
              data-dropzone="true"
              data-date={cell.dateStr}
            >
              {cell.inCurrentMonth && (
                <div class={`text-right w-full p-1 mb-1 text-sm font-semibold ${cell.dateStr === new Date().toISOString().split('T')[0] ? 'text-white' : 'text-gray-400'}`}>
                  <span class={`inline-block w-6 h-6 text-center leading-6 rounded-full ${cell.dateStr === new Date().toISOString().split('T')[0] ? 'bg-brand-cyan' : ''}`}>
                    {cell.dayNumber}
                  </span>
                </div>
              )}
              
              <!-- Map items for this specific day -->
              <div class="flex flex-col gap-1.5 flex-grow overflow-y-auto min-h-[40px] px-1 pb-1">
                {(plannedIdeasByDate[cell.dateStr] || []).map(idea => (
                  <div 
                    draggable="true" 
                    data-idea-id={idea.id}
                    data-idea={JSON.stringify(idea)}
                    class="bg-brand-sky border border-brand-cyan/20 p-2 rounded cursor-pointer hover:shadow-sm transition-all group/card relative idea-card"
                  >
                     <div class="flex items-center gap-1.5 mb-1">
                       {avatars[idea.submitter] ? (
                         <img src={avatars[idea.submitter]} alt={idea.submitter} class="w-5 h-5 rounded-full object-cover shrink-0 border border-white shadow-sm" />
                       ) : (
                         <div class="w-5 h-5 rounded-full bg-brand-cyan text-white flex items-center justify-center font-bold text-[10px] shrink-0 border border-white shadow-sm">
                           {idea.submitter.charAt(0)}
                         </div>
                       )}
                       <span class="text-[10px] font-semibold text-brand-teal truncate">{idea.submitter}</span>
                       <span class={`ml-auto w-2 h-2 rounded-full ${idea.status === 'done' ? 'bg-green-500' : idea.status === 'in progress' ? 'bg-yellow-400' : 'bg-gray-300'}`} title={idea.status}></span>
                     </div>
                     <p class="text-[11px] leading-tight text-brand-navy line-clamp-3 break-words">{idea.idea}</p>

                     <!-- Status Quick Update Overlay (appears on card hover) -->
                     <form method="POST" class="absolute inset-0 bg-white/95 opacity-0 group-hover/card:opacity-100 flex flex-col items-center justify-center transition-opacity rounded p-1">
                        <input type="hidden" name="id" value={idea.id} />
                        <input type="hidden" name="action" value="update_status" />
                        <select name="status" onchange="this.form.submit()" class="text-[10px] p-1 border border-gray-300 rounded block w-full mb-1 bg-white cursor-pointer focus:outline-none">
                           <option value="pending" selected={idea.status === 'pending' || !idea.status}>Wacht</option>
                           <option value="in progress" selected={idea.status === 'in progress'}>Bezig</option>
                           <option value="done" selected={idea.status === 'done'}>Klaar</option>
                        </select>
                        <button type="button" formmethod="POST" name="action" value="delete" class="text-[10px] text-red-600 hover:text-red-800" onclick="if(confirm('Verwijderen?')) { this.form.action.value='delete'; this.form.submit(); }">Verwijder</button>
                     </form>
                  </div>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- RIGHT: Unplanned / Backlog Area -->
    <div class="w-full xl:w-1/4 mt-8 xl:mt-0 xl:sticky xl:top-8 bg-gray-50 border border-gray-200 rounded-xl flex flex-col max-h-[85vh]">
      <div class="p-4 border-b border-gray-200 bg-white rounded-t-xl flex items-center justify-between">
         <h3 class="font-bold text-brand-navy">Ideeën <span class="text-gray-400 text-xs font-normal">({backlogIdeas.length})</span></h3>
         <div class="text-xs text-brand-teal bg-brand-sky px-2 py-1 rounded font-medium">Nog in te plannen</div>
      </div>
      
      <!-- Backlog Dropzone -->
      <div 
        class="p-4 flex-grow overflow-y-auto space-y-3"
        data-dropzone="true"
        data-date="null"
      >
        {backlogIdeas.length === 0 ? (
          <p class="text-sm text-gray-500 italic text-center py-8">Alle ideeën zijn ingepland!</p>
        ) : (
          backlogIdeas.map(idea => (
            <div 
              draggable="true" 
              data-idea-id={idea.id}
              data-idea={JSON.stringify(idea)}
              class="bg-white border border-gray-200 p-3 rounded-lg shadow-sm cursor-pointer hover:shadow hover:border-brand-cyan transition-all group relative idea-card"
            >
               <div class="flex items-start justify-between gap-2 mb-2">
                 <div class="flex items-center gap-2">
                   {avatars[idea.submitter] ? (
                     <img src={avatars[idea.submitter]} alt={idea.submitter} class="w-6 h-6 rounded-full object-cover shrink-0 border border-white shadow-sm" />
                   ) : (
                     <div class="w-6 h-6 rounded-full bg-brand-sky text-brand-cyan flex items-center justify-center font-bold text-xs shrink-0 border border-white shadow-sm">
                       {idea.submitter.charAt(0)}
                     </div>
                   )}
                   <div class="min-w-0">
                     <p class="font-semibold text-brand-navy text-xs truncate">{idea.submitter}</p>
                   </div>
                 </div>
                 <div class={`text-[10px] px-1.5 py-0.5 rounded uppercase font-semibold tracking-wider ${
                    idea.status === 'done' ? 'bg-green-100 text-green-700' :
                    idea.status === 'in progress' ? 'bg-yellow-100 text-yellow-800' :
                    'bg-gray-100 text-gray-600'
                 }`}>
                   {idea.status || 'pending'}
                 </div>
               </div>
               
               <p class="text-sm text-brand-slate line-clamp-3 mb-2">{idea.idea}</p>
               
               {idea.hook && (
                 <p class="text-xs text-brand-teal bg-brand-sky/50 p-1.5 rounded truncate mb-1">
                   <span class="font-semibold">Haakje:</span> {idea.hook}
                 </p>
               )}

               <!-- Hover Actions -->
               <form method="POST" class="absolute inset-0 bg-white/95 opacity-0 group-hover:opacity-100 flex flex-col items-center justify-center transition-opacity rounded-lg p-2 gap-2">
                  <input type="hidden" name="id" value={idea.id} />
                  <input type="hidden" name="action" value="update_status" />
                  <select name="status" onchange="this.form.submit()" class="text-xs p-1.5 border border-gray-300 rounded w-full bg-white cursor-pointer focus:outline-none">
                     <option value="pending" selected={idea.status === 'pending' || !idea.status}>In afwachting</option>
                     <option value="in progress" selected={idea.status === 'in progress'}>Mee bezig</option>
                     <option value="done" selected={idea.status === 'done'}>Klaar</option>
                  </select>
                  <button type="button" formmethod="POST" name="action" value="delete" class="text-xs text-red-600 hover:text-red-800 cursor-pointer" onclick="if(confirm('Weet je het zeker?')) { this.form.action.value='delete'; this.form.submit(); }">Verwijderen</button>
               </form>
            </div>
          ))
        )}
      </div>
    </div>
  </div>

  <!-- Idea Details Modal -->
  <div id="idea-modal" class="fixed inset-0 bg-black/50 z-50 hidden flex items-center justify-center p-4 backdrop-blur-sm transition-opacity">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-lg overflow-hidden flex flex-col max-h-[90vh]">
      <div class="flex items-center justify-between p-4 border-b border-gray-100 bg-gray-50">
        <div class="flex items-center gap-3">
          <div id="modal-avatar" class="w-10 h-10 rounded-full bg-brand-sky text-brand-cyan flex justify-center items-center font-bold text-lg"></div>
          <div>
            <h3 id="modal-submitter" class="font-bold text-brand-navy"></h3>
            <p id="modal-date" class="text-xs text-brand-slate"></p>
          </div>
        </div>
        <button id="modal-close" class="text-gray-400 hover:text-gray-600 p-1 rounded-md hover:bg-gray-200 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      
      <div class="p-6 overflow-y-auto flex-grow space-y-6">
        <div>
          <h4 class="text-xs uppercase tracking-wider font-semibold text-brand-slate mb-2">Content Idee</h4>
          <p id="modal-idea" class="text-brand-navy text-sm leading-relaxed whitespace-pre-wrap"></p>
        </div>

        <div id="modal-hook-container" class="hidden">
          <h4 class="text-xs uppercase tracking-wider font-semibold text-brand-teal mb-2">Haakje / Actualiteit</h4>
          <div class="bg-brand-sky p-3 rounded-lg border border-brand-cyan/20">
            <p id="modal-hook" class="text-brand-navy text-sm"></p>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 pt-4 border-t border-gray-100">
          <div id="modal-visuals-container" class="hidden">
             <h4 class="text-xs uppercase tracking-wider font-semibold text-brand-slate mb-1">Visuals / Link</h4>
             <a id="modal-visuals" href="#" target="_blank" class="text-sm text-brand-cyan hover:underline break-all inline-flex items-center gap-1">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
               <span>Bekijk Link</span>
             </a>
          </div>
          <div id="modal-url-container" class="hidden">
             <h4 class="text-xs uppercase tracking-wider font-semibold text-brand-slate mb-1">Doel URL</h4>
             <a id="modal-url" href="#" target="_blank" class="text-sm text-brand-cyan hover:underline break-all inline-flex items-center gap-1">
               <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h6"/><path d="m21 3-9 9"/><path d="M15 3h6v6"/></svg>
               <span>Doelpagina</span>
             </a>
          </div>
        </div>
      </div>
      
      <div class="p-4 border-t border-gray-100 bg-gray-50 flex items-center justify-between">
         <div class="flex items-center gap-2">
           <span class="text-sm font-medium text-brand-slate">Status:</span>
           <span id="modal-status-badge" class="text-xs px-2 py-1 rounded font-semibold uppercase tracking-wider"></span>
         </div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ avatars }}>
  // Pass avatars to window for the modal
  window.avatarsMap = avatars;

  // Setup HTML5 Drag and Drop logic
  document.addEventListener('DOMContentLoaded', () => {
    let draggedIdeaId: string | null = null;
    let isDragging = false;
    
    // 1. Draggable items (Cards)
    const draggableItems = document.querySelectorAll('[draggable="true"]');
    draggableItems.forEach(item => {
      item.addEventListener('dragstart', (e) => {
        isDragging = true;
        draggedIdeaId = (e.target as HTMLElement).getAttribute('data-idea-id');
        // Slight opacity makes it look like it's being picked up
        setTimeout(() => (e.target as HTMLElement).classList.add('opacity-50'), 0);
      });
      
      item.addEventListener('dragend', (e) => {
        setTimeout(() => isDragging = false, 50); // slight delay to prevent click firing immediately
        (e.target as HTMLElement).classList.remove('opacity-50');
        draggedIdeaId = null;
        
        // Cleanup all dropzone highlights
        document.querySelectorAll('[data-dropzone="true"]').forEach(zone => {
          zone.classList.remove('bg-brand-sky/50', 'ring-2', 'ring-inset', 'ring-brand-cyan');
        });
      });
    });

    // 2. Dropzones (Days in calendar + Backlog container)
    const dropZones = document.querySelectorAll('[data-dropzone="true"]');
    dropZones.forEach(zone => {
      zone.addEventListener('dragover', (e) => {
        e.preventDefault();
        const dateAttr = (e.currentTarget as HTMLElement).getAttribute('data-date');
        if (dateAttr !== '') {
           (e.currentTarget as HTMLElement).classList.add('bg-brand-sky/50', 'ring-2', 'ring-inset', 'ring-brand-cyan');
        }
      });

      zone.addEventListener('dragleave', (e) => {
        (e.currentTarget as HTMLElement).classList.remove('bg-brand-sky/50', 'ring-2', 'ring-inset', 'ring-brand-cyan');
      });

      zone.addEventListener('drop', (e) => {
        e.preventDefault();
        (e.currentTarget as HTMLElement).classList.remove('bg-brand-sky/50', 'ring-2', 'ring-inset', 'ring-brand-cyan');
        
        const targetDate = (e.currentTarget as HTMLElement).getAttribute('data-date');
        if (draggedIdeaId && targetDate !== '') {
          const form = document.getElementById('move-form') as HTMLFormElement;
          const idInput = document.getElementById('move-id') as HTMLInputElement;
          const dateInput = document.getElementById('move-date') as HTMLInputElement;
          
          if (form && idInput && dateInput) {
            idInput.value = draggedIdeaId;
            dateInput.value = targetDate as string;
            form.submit();
          }
        }
      });
    });

    // 3. Modal Logic
    const modal = document.getElementById('idea-modal');
    const modalClose = document.getElementById('modal-close');

    document.querySelectorAll('.idea-card').forEach(card => {
      card.addEventListener('click', (e) => {
        // Ignore clicks on form elements inside the card
        if ((e.target as HTMLElement).tagName.toLowerCase() === 'select' || 
            (e.target as HTMLElement).tagName.toLowerCase() === 'button' ||
            (e.target as HTMLElement).tagName.toLowerCase() === 'option') {
          return;
        }

        // Ignore if we were just dragging
        if (isDragging) return;

        const dataStr = card.getAttribute('data-idea');
        if (!dataStr) return;
        
        try {
          const idea = JSON.parse(dataStr);
          
          const modalAvatar = document.getElementById('modal-avatar')!;
          modalAvatar.innerHTML = '';
          const avatarUrl = window.avatarsMap ? window.avatarsMap[idea.submitter] : null;
          
          if (avatarUrl) {
             const img = document.createElement('img');
             img.src = avatarUrl;
             img.className = 'w-10 h-10 rounded-full object-cover border-2 border-white shadow-sm';
             img.alt = idea.submitter;
             modalAvatar.appendChild(img);
             modalAvatar.className = 'w-10 h-10 flex shrink-0';
          } else {
             modalAvatar.textContent = idea.submitter.charAt(0);
             modalAvatar.className = 'w-10 h-10 rounded-full bg-brand-sky text-brand-cyan flex justify-center items-center font-bold text-lg border-2 border-white shadow-sm';
          }

          document.getElementById('modal-submitter')!.textContent = idea.submitter;
          
          const createdDate = new Date(idea.created_at).toLocaleDateString('nl-NL', { day: 'numeric', month: 'short', year: 'numeric' });
          document.getElementById('modal-date')!.textContent = `Ingediend op ${createdDate}`;
          document.getElementById('modal-idea')!.textContent = idea.idea;

          const hookContainer = document.getElementById('modal-hook-container')!;
          if (idea.hook) {
            document.getElementById('modal-hook')!.textContent = idea.hook;
            hookContainer.classList.remove('hidden');
          } else {
            hookContainer.classList.add('hidden');
          }

          const visContainer = document.getElementById('modal-visuals-container')!;
          if (idea.visuals) {
            const visAnchor = document.getElementById('modal-visuals') as HTMLAnchorElement;
            visAnchor.href = idea.visuals.startsWith('http') ? idea.visuals : `https://${idea.visuals}`;
            visContainer.classList.remove('hidden');
          } else {
            visContainer.classList.add('hidden');
          }

          const urlContainer = document.getElementById('modal-url-container')!;
          if (idea.target_url) {
            const urlAnchor = document.getElementById('modal-url') as HTMLAnchorElement;
            urlAnchor.href = idea.target_url.startsWith('http') ? idea.target_url : `https://${idea.target_url}`;
            urlContainer.classList.remove('hidden');
          } else {
            urlContainer.classList.add('hidden');
          }

          const statusBadge = document.getElementById('modal-status-badge')!;
          const statusMap: Record<string, string> = {
            'pending': 'In afwachting',
            'in progress': 'Mee bezig',
            'done': 'Klaar'
          };
          statusBadge.textContent = statusMap[idea.status] || idea.status || 'In afwachting';
          
          statusBadge.className = `text-xs px-2 py-1 rounded font-semibold uppercase tracking-wider ${
             idea.status === 'done' ? 'bg-green-100 text-green-700' :
             idea.status === 'in progress' ? 'bg-yellow-100 text-yellow-800' :
             'bg-gray-200 text-gray-700'
          }`;

          modal?.classList.remove('hidden');
        } catch (err) {
          console.error('Failed to parse data', err);
        }
      });
    });

    modalClose?.addEventListener('click', () => {
      modal?.classList.add('hidden');
    });

    modal?.addEventListener('click', (e) => {
      if (e.target === modal) {
        modal.classList.add('hidden');
      }
    });

  });
</script>
