---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="ZeeZicht Content Aanlever Tool" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | ZeeZicht</title>
  </head>
  <body class="bg-gray-50 text-brand-slate font-sans antialiased flex flex-col min-h-screen">
    <header class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-3 group">
          <img src="/logo.svg" alt="Zee-Zicht Logo" class="h-6 w-auto transition-all duration-300 object-contain" />
          <span class="font-bold text-lg tracking-tight group-hover:text-brand-teal text-brand-navy transition-colors">Aanlever Tool</span>
        </a>
        <nav class="flex items-center gap-2 sm:gap-6 text-sm font-medium">
          <a href="/" class="text-brand-slate hover:text-brand-cyan transition-colors px-3 py-2 rounded-md hover:bg-gray-50">Aanleveren</a>
          <a href="/dashboard" class="text-brand-teal bg-brand-sky hover:bg-blue-100 transition-colors px-3 py-2 rounded-md">Dashboard (Pheadra)</a>
        </nav>
      </div>
    </header>
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <slot />
    </main>
    <footer class="bg-white border-t border-gray-200 py-6 mt-auto">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500">
        &copy; {new Date().getFullYear()} ZeeZicht. Alle rechten voorbehouden.
      </div>
    </footer>
  </body>
</html>
