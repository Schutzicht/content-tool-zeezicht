---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="ZeeZicht Content Aanlever Tool" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator} />
    <title>{title} | ZeeZicht</title>
  </head>
  <body class="bg-[#F8FAFC] text-brand-slate font-sans antialiased flex flex-col min-h-screen">
    <header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-gray-200/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-20 flex items-center justify-between">
        <a href="/" class="flex items-center gap-4 group">
          <img src="/logo-zeezicht.webp" alt="ZeeZicht Logo" class="h-10 w-auto transition-transform duration-300 group-hover:scale-105 object-contain" />
          <div class="flex flex-col">
            <span class="font-bold text-xl tracking-tight text-brand-navy transition-colors">Aanlever Tool</span>
            <span class="text-[10px] uppercase tracking-[0.2em] text-brand-teal font-semibold">ZeeZicht Socials</span>
          </div>
        </a>
        <nav class="flex items-center gap-2 sm:gap-4 text-sm font-medium">
          <a href="/" class="text-brand-slate hover:text-brand-cyan transition-all px-4 py-2 rounded-full hover:bg-gray-100/50">Aanleveren</a>
          <a href="/dashboard" class="text-brand-teal bg-brand-sky hover:bg-brand-sky/80 transition-all px-5 py-2.5 rounded-full font-bold shadow-sm shadow-brand-sky/20">Dashboard</a>
        </nav>
      </div>
    </header>
    <main class="flex-grow w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 md:py-12">
      <slot />
    </main>
    <footer class="bg-white border-t border-gray-200 py-6 mt-auto">
      <div class="max-w-7xl mx-auto px-4 text-center text-sm text-gray-500">
        &copy; {new Date().getFullYear()} ZeeZicht. Alle rechten voorbehouden.
      </div>
    </footer>
  </body>
</html>
